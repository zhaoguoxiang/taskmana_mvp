# TaskMana — required environment variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# REQUIRED — JWT signing key.  Generate one:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
TASKMANA_SECRET_KEY=change-me-to-a-random-secret

# OPTIONAL — JWT token lifetime in minutes (default: 1440 = 24 hours)
# TASKMANA_TOKEN_EXPIRE_MINUTES=1440
